      variance: 0,
      variance_pct: 0,
      status: 'ok',
    })

    const marketing = result.find((item) => item.category === 'Marketing')
    expect(marketing).toEqual({
      category: 'Marketing',
      budget: 300,
      actual: 330,
      variance: 30,
      variance_pct: 10,
      status: 'ok',
    })
  })

  it('returns warning and critical statuses by variance threshold', () => {
